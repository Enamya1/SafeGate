## Function Implementation Specifications

### Core Deterministic Functions

#### 1. search_products(keyword)
```python
def search_products(keyword: str, user_id: int, limit: int = 20, offset: int = 0):
    """Full-text search across product catalog with fuzzy matching"""
    query = """
        SELECT p.*, 
               MATCH(p.title, p.description) AGAINST (:keyword IN BOOLEAN MODE) as relevance
        FROM products p
        WHERE p.status = 'available'
          AND (p.dormitory_id IN (SELECT dormitory_id FROM users WHERE id = :user_id)
               OR p.dormitory_id IS NULL)
        HAVING relevance > 0
        ORDER BY relevance DESC, p.created_at DESC
        LIMIT :limit OFFSET :offset
    """
    # Parameterized execution with user context
```

#### 2. search_by_price(max_price)
```python
def search_by_price(max_price: float, user_id: int, limit: int = 20):
    """Filter products below specified price point"""
    query = """
        SELECT p.*
        FROM products p
        WHERE p.status = 'available'
          AND p.price <= :max_price
          AND (p.dormitory_id IN (SELECT dormitory_id FROM users WHERE id = :user_id)
               OR p.dormitory_id IS NULL)
        ORDER BY p.price ASC, p.created_at DESC
        LIMIT :limit
    """
```

#### 3. search_by_category(category)
```python
def search_by_category(category: str, user_id: int, limit: int = 20):
    """Retrieve products within a given category"""
    query = """
        SELECT p.*
        FROM products p
        JOIN categories c ON p.category_id = c.id
        WHERE p.status = 'available'
          AND c.name = :category
          AND (p.dormitory_id IN (SELECT dormitory_id FROM users WHERE id = :user_id)
               OR p.dormitory_id IS NULL)
        ORDER BY p.created_at DESC
        LIMIT :limit
    """
```

#### 4. get_product(product_id)
```python
def get_product(product_id: int, user_id: int):
    """Return full product details for a single SKU"""
    query = """
        SELECT p.*, pi.image_path, t.name as tag_name
        FROM products p
        LEFT JOIN product_images pi ON p.id = pi.product_id
        LEFT JOIN product_tags pt ON p.id = pt.product_id
        LEFT JOIN tags t ON pt.tag_id = t.id
        WHERE p.id = :product_id
          AND p.status = 'available'
          AND (p.dormitory_id IN (SELECT dormitory_id FROM users WHERE id = :user_id)
               OR p.dormitory_id IS NULL)
    """
```

#### 5. get_similar_products(product_id)
```python
def get_similar_products(product_id: int, user_id: int, limit: int = 10):
    """Return ranked list of related products"""
    query = """
        WITH target_product AS (
            SELECT category_id, price, dormitory_id 
            FROM products WHERE id = :product_id
        )
        SELECT p.*,
               CASE 
                   WHEN p.category_id = tp.category_id THEN 3
                   WHEN ABS(p.price - tp.price) < tp.price * 0.3 THEN 2
                   ELSE 1
               END as similarity_score
        FROM products p, target_product tp
        WHERE p.id != :product_id
          AND p.status = 'available'
          AND (p.dormitory_id = tp.dormitory_id 
               OR p.dormitory_id IN (SELECT dormitory_id FROM users WHERE id = :user_id))
        ORDER BY similarity_score DESC, p.created_at DESC
        LIMIT :limit
    """
```

